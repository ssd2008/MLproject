APP_ENV=local
DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=postgresql://med_user:med_password@localhost:5432/med_assistant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=document_chunks_v1

# Lightweight local defaults. They make the full backend runnable without PyTorch.
EMBEDDING_BACKEND=hash
EMBEDDING_DIMENSION=1024
RERANKER_BACKEND=lexical
ANSWER_BACKEND=extractive

# Production-quality ML options:
# EMBEDDING_BACKEND=sentence-transformers
# EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
# RERANKER_BACKEND=cross-encoder
# RERANKER_MODEL_NAME=BAAI/bge-reranker-large

# Optional generative answers:
# ANSWER_BACKEND=openai
# OPENAI_API_KEY=...
# OPENAI_MODEL=gpt-4.1-mini
