APP_ENV=local
DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=postgresql://med_user:med_pass@localhost:5432/med_assistant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=document_chunks_e5_large_v1
MAX_DOCUMENT_SIZE_MB=10
MAX_VIDEO_SIZE_MB=500

EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=8
EMBEDDING_DEVICE=cpu
NORMALIZE_EMBEDDINGS=true

RERANKER_BACKEND=cross-encoder
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_BATCH_SIZE=4
RERANKER_DEVICE=cpu

ASR_BACKEND=faster-whisper
ASR_MODEL_NAME=small
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_BEAM_SIZE=5
ASR_VAD_FILTER=true
VIDEO_CHUNK_DURATION_SECONDS=20
VIDEO_CHUNK_OVERLAP_SECONDS=2

ANSWER_BACKEND=extractive

# Lightweight options for tests or machines where ML dependencies are unavailable:
# EMBEDDING_BACKEND=hash
# RERANKER_BACKEND=lexical
# ASR_BACKEND=disabled
# QDRANT_COLLECTION_NAME=document_chunks_v1

# Optional generative answers:
# ANSWER_BACKEND=openai
# OPENAI_API_KEY=...
# OPENAI_MODEL=gpt-4.1-mini
